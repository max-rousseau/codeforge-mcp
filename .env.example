# CodeForge MCP runtime configuration.
# Copy this file to .env and edit values before running `docker compose up`.

# YOLO_MODE: when true, the sandbox can reach ANY internet destination.
# Credential substitution still only applies to tokens defined in apis/*/config.json —
# unconfigured hosts receive no credentials. Disabling the domain allowlist lets
# sandboxed code exfiltrate data to arbitrary hosts. Only enable in trusted environments.
YOLO_MODE=false

# USER_AGENT: the proxy overwrites every outbound request's User-Agent header with
# this value, replacing Deno's default (e.g. "Deno/2.3.1"). Gives CodeForge traffic
# a single, consistent identity on the wire regardless of runtime version.
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"

# REDACTING_STRINGS: comma-separated list of strings the proxy replaces with "REDACTED"
# on outbound requests. Use this to prevent PII (emails, names, etc.) from leaking to
# external APIs. Leave empty if you have nothing to redact.
REDACTING_STRINGS=jane.doe@gmail.com,Jane Doe,123 Main St

# DEBUG_MODE: when true, logs full request/response payloads in the proxy and
# sandbox I/O in the MCP server. Payloads are logged BEFORE credential
# substitution (outbound) and AFTER reverse substitution (inbound), so real
# secrets never appear in logs — only token names. Produces significant output.
DEBUG_MODE=false
